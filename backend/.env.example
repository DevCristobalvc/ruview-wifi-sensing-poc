# Copia este archivo a .env y rellena los valores.

# Puerto del backend
PORT=8090

# Ruta al binario del sensor Rust (relativa al directorio backend/).
# Compílalo con: cargo +stable-x86_64-pc-windows-gnu build --release  (en /sensor)
SENSOR_CMD=../sensor/target/release/ruview-rssi-sensor.exe
SENSOR_INTERVAL_MS=250

# DeepSeek (API compatible con OpenAI)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat
